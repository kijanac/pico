{
  "name": "pico-workspace",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.5.2",
  "engines": {
    "node": ">=26.1.0"
  },
  "scripts": {
    "dev:bridge": "BRIDGE_DB=data/bridge.db PI_WORKSPACES_DIR=. pnpm --filter pi-bridge dev",
    "dev:bridge:mock": "BRIDGE_DB=data/bridge.db PI_WORKSPACES_DIR=. PI_USE_MOCK=1 pnpm --filter pi-bridge dev",
    "dev:mobile": "pnpm --filter pico dev",
    "typecheck": "pnpm --filter @pico/protocol typecheck && pnpm --filter pi-bridge typecheck",
    "smoke:bridge": "pnpm --filter pi-bridge smoke",
    "build:mobile": "pnpm --filter pico build",
    "release:bump": "node scripts/bump-version.mjs",
    "check": "pnpm typecheck && pnpm --filter pico build"
  }
}
