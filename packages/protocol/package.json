{
  "name": "@pico/protocol",
  "version": "1.0.2",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./rpc": {
      "types": "./dist/rpc.d.ts",
      "import": "./dist/rpc.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/rpc": "^0.75.1",
    "effect": "^3.21.4"
  },
  "devDependencies": {
    "typescript": "^5.9.0"
  }
}
