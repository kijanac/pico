{
  "name": "@pico/protocol",
  "version": "1.0.2",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./trpc": {
      "types": "./dist/trpc.d.ts",
      "import": "./dist/trpc.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@trpc/server": "^11.17.0",
    "effect": "^3.21.4",
    "valibot": "^1.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.0"
  }
}
