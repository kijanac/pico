{
  "name": "@pico/host",
  "version": "1.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "packageManager": "pnpm@10.5.2",
  "engines": {
    "node": ">=26.1.0"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepack": "pnpm run build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pico/host-runtime": "workspace:*",
    "@pico/protocol": "workspace:*",
    "@trpc/client": "^11.17.0",
    "effect": "^3.18.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.9.0"
  }
}
