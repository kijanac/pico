{
  "name": "@pico/cli",
  "version": "1.0.1",
  "type": "module",
  "bin": {
    "pico": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "packageManager": "pnpm@10.5.2",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "rm -rf dist && tsc -p tsconfig.build.json && chmod +x dist/index.js",
    "prepack": "pnpm run build",
    "pair": "tsx src/index.ts pair",
    "pair-code": "tsx src/index.ts pair-code",
    "serve": "tsx src/index.ts serve",
    "status": "tsx src/index.ts status",
    "install:host": "pnpm run build && node dist/index.js install",
    "uninstall:host": "tsx src/index.ts uninstall",
    "start:host": "tsx src/index.ts start",
    "stop:host": "tsx src/index.ts stop",
    "logs:host": "tsx src/index.ts logs",
    "doctor": "tsx src/index.ts doctor",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@effect/cli": "^0.75.2",
    "@effect/platform": "^0.96.2",
    "@effect/platform-node": "^0.107.0",
    "@effect/rpc": "^0.75.1",
    "@pico/host": "workspace:*",
    "@pico/protocol": "workspace:*",
    "effect": "^3.21.4",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0"
  }
}
