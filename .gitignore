# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.out/
.vite/
.cache/
coverage/
*.tsbuildinfo
# Compiled updater (built from deploy/host-update.mts by `pnpm --filter @pico/host build:updater`)
packages/host/deploy/host-update.mjs
# Stray tsc emit beside TS sources (package src trees are TypeScript-only)
packages/*/src/**/*.js
packages/*/src/**/*.js.map

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local env/config
.env
.env.*
!.env.example

# Bridge runtime state
bridge/data/
data/
*.db
*.db-*

# Capacitor/native generated build artifacts
pico/android/.gradle/
pico/android/app/build/
pico/android/build/
pico/ios/App/build/
pico/ios/App/Pods/
pico/ios/App/DerivedData/

# Tarball snapshots/import artifacts
*.tar
*.tar.gz
*.tgz
*.tar.bz2
*.tbz2
*.tar.xz
*.txz

# Logo exploration generated artifacts
# Canonical source icon lives at pico/assets/app-icon.png.
design/logo-exploration*/

# Agent/local scratch
.claude/
.DS_Store
