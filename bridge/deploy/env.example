# pi-bridge environment file.
#
# Copy this to /etc/pi-bridge/env on the server, fill in the secrets,
# then chmod 600 + chown root:pi-bridge. systemd reads it via the
# EnvironmentFile= directive in pi-bridge.service.
#
# The unit file sets sensible defaults for HOST, PORT, BRIDGE_DB, HOME
# and NODE_ENV.
#
# Authentication options:
#   1. Preferred for subscription accounts: SSH to the server and run pi /login
#      as the pi-bridge user so credentials are stored under
#      /var/lib/pi-bridge/.pi/agent/auth.json.
#   2. API-key mode: uncomment one of the provider env vars below.
#
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# Optional overrides (uncomment to use):
#
# HOST=127.0.0.1            # listen address; 127.0.0.1 + tailscale serve is the recommended deploy
# PORT=7777                 # listen port
# BRIDGE_DB=/var/lib/pi-bridge/bridge.db
# HOME=/var/lib/pi-bridge   # pi's auth + session JSONLs live under $HOME/.pi/
# PI_WORKSPACES_DIR=/var/lib/pi-bridge/workspaces # default directory picker root
#
# Effect log level: silent | error | warning | info | debug | trace
# EFFECT_LOG_LEVEL=info
